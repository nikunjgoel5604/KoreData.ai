# .env.example — Kore_data-ex v10.0 (Backend Settings)
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in all values before running the server.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (MySQL) ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=kore_data
DB_USER=root
DB_PASS=your_mysql_password_here

# ── Email / SMTP (for OTP verification emails) ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SENDER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here

# ── OTP Settings ──────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10

# ── Authentication & Security ──────────────────────────────────────────────────
APP_SECRET=change_this_to_a_long_random_secret_string
JWT_KEYS=change_this_to_a_long_random_secret_string

# ── Folder Storage & AI Paths ─────────────────────────────────────────────────
# UPLOAD_FOLDER is where user datasets and models are saved
UPLOAD_FOLDER=./storage
# MODEL_PATHS is where trained pickle models are saved
MODEL_PATHS=./models
# AI_KEYS is the comma-separated list of APIs keys (e.g. Gemini, OpenAI)
AI_KEYS=your_ai_keys_here

# ── Logging & Mode ────────────────────────────────────────────────────────────
LOGGING_LEVEL=INFO
# Set DEMO_MODE to "true" to skip real email sending and print OTP in terminal logs.
DEMO_MODE=true
# Port for the uvicorn web server
PORT=8000
