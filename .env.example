# .env.example — Kore_data-ex v9.0
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in all values before running the server.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (MySQL) ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=kore_data
DB_USER=root
DB_PASSWORD=your_mysql_password_here

# ── Email / SMTP (for OTP emails) ─────────────────────────────────────────────
# Using Gmail: enable "App Passwords" in your Google account settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SENDER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here

# ── OTP Settings ──────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=2

# ── App ───────────────────────────────────────────────────────────────────────
APP_SECRET=change_this_to_a_long_random_secret_string

# ── Demo Mode ─────────────────────────────────────────────────────────────────
# Set to "true" to skip real email sending and return OTP in API response.
# MUST be "false" in production.
DEMO_MODE=false

# ── Server ────────────────────────────────────────────────────────────────────
# PORT is set automatically by Railway/Heroku — do not override in production.
PORT=8000
